      "id": "filter",
      "name": "Filter Value Bets",
      "type": "function",
      "parameters": {
        "functionCode": "// Filter matches where DC odds are between 1.10 and 1.50\nconst matches = $input.all();\nconst valueBets = matches.filter(m => {\n  const dcOdds = calculateDCOdds(m.json.odds_1, m.json.odds_X, m.json.odds_2);\n  return dcOdds >= 1.10 && dcOdds <= 1.50;\n});\nreturn valueBets;"
