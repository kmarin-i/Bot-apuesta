# The Odds API — https://theoddsapi.com
ODDS_API_KEY=your_api_key_here

# Telegram Bot — @Lucasapuesta_bot
TELEGRAM_BOT_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=7931331993

# X (Twitter) — credenciales para scraping
X_USERNAME=your_x_username
X_PASSWORD=your_x_password

# Base de datos
DATABASE_URL=sqlite:///data/apuestas.db

# Sports (NBA, NFL, MLB, NHL, UFC, Futbol)
SPORT=nba

# Apuestas minimum odd para considerar
MIN_ODD=1.5
MAX_ODD=5.0

# Value threshold (ej: 1.05 = 5% edge sobre fair odds)
VALUE_THRESHOLD=1.05